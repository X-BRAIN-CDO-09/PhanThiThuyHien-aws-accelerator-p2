# Copy this file to terraform.tfvars and replace the email address.
alert_email = "you@example.com"

# Amazon Macie is a regional service. Singapore is used by default.
aws_region = "ap-southeast-1"

# Optional overrides:
# project_name         = "macie-sensitive-data-lab"
# bucket_name          = "a-globally-unique-bucket-name"
# macie_inventory_wait = "2m"
# force_destroy_bucket = true
# tags = {
#   Environment = "lab"
#   Owner       = "your-name"
# }

